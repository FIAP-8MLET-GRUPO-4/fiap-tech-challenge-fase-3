# Caminho para a pasta de dados (default: ./data)
DATA_DIR=./data

# Caminho para artefatos de modelos treinados (joblib)
MODELS_DIR=./models_artifacts

# Caminho para relatórios e figuras geradas
REPORTS_DIR=./reports

# Seed global para reprodutibilidade
RANDOM_SEED=42

# Tamanho da amostra para experimentos rápidos (0 = dataset completo)
SAMPLE_SIZE=0
